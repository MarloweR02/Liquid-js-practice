<sort-by class="sort-by" data-section-id="{{ section.id }}">
  <div class="sort-by__header">
    {% case collection.sort_by %}
      {% when 'manual' %}
        Manually
      {% when 'best-selling' %}
        Best Selling
      {% when 'title-ascending' %}
        Title: A to Z
      {% when 'title-descending' %}
        Title: Z to A
      {% when 'price-ascending' %}
        Price: Low to High
      {% when 'price-descending' %}
        Price: High to Low
      {% when 'created-ascending' %}
        Created: Oldest to Newest
      {% when 'created-descending' %}
        Created: Newest to Oldest
      {% else %}
        Options
    {% endcase %}
  <ul class="sort-by__options">
    <li class="sort-by__option">
      <a href="{{ collection.url | sort_by: 'manual' }}" class="sort-option__link">Manually</a>
    </li>
    <li class="sort-by__option">
      <a href="{{ collection.url | sort_by: 'best-selling' }}" class="sort-option__link">Best Selling</a>
    </li>
    <li class="sort-by__option">
      <a href="{{ collection.url | sort_by: 'title-ascending' }}" class="sort-option__link">Title: A to Z</a>
    </li>
    <li class="sort-by__option">
      <a href="{{ collection.url | sort_by: 'title-descending' }}" class="sort-option__link">Title: Z to A</a>
    </li>
    <li class="sort-by__option">
      <a href="{{ collection.url | sort_by: 'price-ascending' }}" class="sort-option__link">Price: Low to High</a>
    </li>
    <li class="sort-by__option">
      <a href="{{ collection.url | sort_by: 'price-descending' }}" class="sort-option__link">Price: High to Low</a>
    </li>
    <li class="sort-by__option">
      <a href="{{ collection.url | sort_by: 'created-ascending' }}" class="sort-option__link">Created: Oldest to Newest</a>
    </li>
    <li class="sort-by__option">
      <a href="{{ collection.url | sort_by: 'created-descending' }}" class="sort-option__link">Created: Newest to Oldest</a>
    </li>
  </ul>
  </div>
  
</sort-by>

<style>
  .sort-by__header{
    border: 1px solid black;
    padding: 0.4rem 0.8rem;
    border-radius: 0.4rem;
    width: 220px;
    position: relative;
    user-select: none;
  }

  .sort-by__options{
    list-style-type: none;
    position: absolute;
    z-index: 100;
    background-color: white;
    width: 100%;
    left: 0;
    top: 100%;
    border-radius: 0.4rem;
    transform: scaleY(0);
    transform-origin: top;
    border: 1px solid black;
    pointer-events: none;
    margin-top: 10px;
    transition: transform 0.25s ease;
  }

  .sort-by__options > li {
    display: flex;
  }

  .sort-by__options > li > a{
    color: inherit;
    text-decoration: none;
    width: 100%;
    transition: all 0.15s ease;
    padding: 0.4rem 0.8rem;
  }
  .sort-by__options > li > a:hover{
    background-color: black;
    color: white;
  }

  sort-by[open] .sort-by__options{
    transform: scaleY(1);
    pointer-events: all;
  }
</style>