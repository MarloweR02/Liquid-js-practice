<script src={{ "predictive-search.js" | asset_url }} defer></script>

<predictive-search id="PredictiveSearch"data-section-id="{{ section.id }}">
  <div class="predictive-search__main">
    <div class="predictive-search__bar">
      <input type="text" class="predictive-search__input" placeholder="Search" >
      <div class="svg-wrapper predictive-search__icon">
        {{ "icon-magnifying-glass.svg" | inline_asset_content }}
      </div>
    </div>
    {% render "search-results" %}
  </div>
  <div class="predictive-search__overlay"></div>
</predictive-search>

<style>
  .predictive-search__main{
    position: fixed;
    top: -100%;
    left: 0;
    width: 100%;
    height: 150px;
    background-color: white;
    z-index: 999;
    transition: all 0.3s ease;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  predictive-search[open] .predictive-search__main{
    top: 0;
  }
  
  .predictive-search__overlay{
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    background-color: black;
    z-index: 998;
    opacity: 0;
    transition: all 0.3s ease;
    pointer-events: none;
  }
  predictive-search[open] .predictive-search__overlay{
    opacity: 0.8;
    pointer-events: all;
  }

  .predictive-search__bar{
    position: relative;
  }

  .predictive-search__bar{
    max-width: 400px;
    width: 100%;
  }

  .predictive-search__input{
    width: 100%;
    padding: 1rem 2rem;
    border-radius: 0.4rem;
    border: 1px solid rgb(122, 122, 122)
  }

  .predictive-search__icon{
    position: absolute;
    top: 50%;
    transform: translateY(-50%);

    right: 1.2rem;
  }
  </style>