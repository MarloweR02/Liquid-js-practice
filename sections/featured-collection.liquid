<div class="featured-collection">
  <div class="page-width featured-collection__inner">
    <div class="featured-collection__header-container">
      <h2 class="featured-collection__header">{{ section.settings.title }}</h2>
      <p class="featured-collection__description">{{ section.settings.description }}</p>
    </div>
    <div class="featured-collection__body"> 
      {% for product in section.settings.collection.products limit: 4 %}
        {% render "product-card" product:product%}
      {% endfor %}
    </div>
  </div>
</div>

<style>

  .featured-collection{
    padding: 6rem 0;
  }

  .featured-collection__inner{
    display: flex;
    flex-direction: column;
    gap: 6rem;
  }

  .featured-collection__header-container{
      display: flex;
      flex-direction: column;
      text-align: center;
      gap: 1rem;
  }

  .featured-collection__body{
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }
</style>

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    }
  ],
  "presets": [
    {
      "name": "Featured collection"
    }
  ]
}
{% endschema %}