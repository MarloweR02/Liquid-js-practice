<div class="hero">
  <div class="page-width hero__inner">
    <h1 class="hero__title">{{ section.settings.hero_title }}</h1>
  </div>
</div>

<style>
  .hero{
    padding: 6rem 0;
  }

  .hero__inner{
    height: 65vh;
    align-items: center;
    justify-content: center;
    display: flex;
    border-radius: 24px;
    background-color: {{ section.settings.bg_color }};    
  }

  .hero__title{
    color: white;
  }
</style>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Hero background color"
    },
    {
      "type": "text",
      "id": "hero_title",
      "label": "Title"
    }
  ]
}
{% endschema %}