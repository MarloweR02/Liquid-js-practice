<div class="hero">
  {{ section.settings.bg_image |  image_url: width: 1000 | image_tag  }}
  <div class="hero-wrapper page-width">
    {% for block in section.blocks %}
      {% case block.type %}
        {% when "heading" %}
          <h1 class="hero__heading">{{ block.settings.title }}</h1>
        {% when "description" %}
          <p class="hero__description">{{ block.settings.description }}</p>
        {% when "button" %}
          <button class="hero__button">{{ block.settings.btn_title }}</button>
      {% endcase %}
    {% endfor %}
  </div>
</div>

<style>
  .hero{
    width: 100%;
    height: 80vh;
    position: relative;
    display: flex;
    justify-content: center;
  }
  .hero > img{
    width: 100%;
    height: 100%;
    object-fit: cover;

  }

  .hero::before {
  content: "";
  position: absolute;
  inset: 0;

  background: rgba(0, 0, 0, 0.4); /* dark overlay */
  z-index: 1;
}

  .hero-wrapper{
    position: absolute;
    width: 100%;
    z-index: 10;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .hero__button{
    background-color: white;
    color: black;
    padding: 1.2rem 4rem;
    border: none;
    border-radius: 100px;
    cursor: pointer;
    width: min-content;
  }

  .hero__heading{
    color: white;
  }

  .hero__description{
    color: rgb(219, 219, 219);
  }
</style>
{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image"
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name":"Heading",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        }
      ]
    },
    {
      "type": "description",
      "name":"Description",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "description",
          "label": "Description"
        }
      ]
    },
    {
      "type": "button",
      "name":"Button",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "btn_title",
          "label": "Button title"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}